    <script>
        // ===== CONFIG - FULLY CONFIGURED =====
        const API_URL = 'https://script.google.com/macros/s/AKfycby15JLR-Q7ZBeqK0pTmbdNdEwKMrU13gEBqc434qXhkTEjWKEX4nERFFKXJpmvQn_t6/exec';
        
        const DRIVE_FOLDER_URL = 'https://drive.google.com/drive/u/0/folders/1myfWEdRk9g82CZGHIQOUtTZaFfxgDa5H';
        const SHEET_ID = '1cpujcQ7kheqGi2ZGJ1jyPM66qsq2ZIn3w8OuiMOpgIw';

        // ===== STATE =====
        let ordersData = [];
        let itemsData = [];
        let currentVendor = null;
        let currentOrder = null;
        let currentItem = null;
        let qcResults = [];
        let uploadItemInfo = null;
        let completedItems = new Set();
        let selectedVideoFile = null;

        // ===== INIT =====
        document.addEventListener('DOMContentLoaded', () => {
            loadSaved();
            loadData();
            updateStats();
            setupDragAndDrop();
        });

        // ===== DATA LOADING =====
        async function loadData() {
            const loading = document.getElementById('loading1');
            const dropdown = document.getElementById('vendorSelect');
            const errorBanner = document.getElementById('errorBanner');
            const errorMessage = document.getElementById('errorMessage');
            
            loading.classList.add('active');
            dropdown.disabled = true;
            dropdown.innerHTML = '<option>Loading...</option>';
            setConnected('connecting');

            // Check if API_URL is set
            if (API_URL === 'REPLACE_WITH_YOUR_WEB_APP_URL') {
                loading.classList.remove('active');
                dropdown.disabled = true;
                dropdown.innerHTML = '<option>-- Setup Required --</option>';
                setConnected(false);
                
                errorBanner.style.display = 'block';
                errorMessage.innerHTML = `
                    <strong>⚠️ API Not Configured</strong><br><br>
                    Please follow these steps:<br>
                    1. Open your Google Sheet: <a href="https://docs.google.com/spreadsheets/d/${SHEET_ID}/edit" target="_blank" style="color:var(--primary);">Open Sheet</a><br>
                    2. Go to Extensions → Apps Script<br>
                    3. Paste the Apps Script code (see artifact)<br>
                    4. Deploy as Web App (Anyone access)<br>
                    5. Copy Web App URL<br>
                    6. Replace <code>REPLACE_WITH_YOUR_WEB_APP_URL</code> in this HTML file
                `;
                return;
            }

            try {
                const res = await fetch(API_URL);
                
                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                }
                
                const data = await res.json();

                if (data.success) {
                    ordersData = data.orders.map(o => ({
                        fleek_id: o.fleek_id ? o.fleek_id.toString() : '',
                        vendor: o.vendor ? o.vendor.toString() : '',
                        status: o.latest_status ? o.latest_status.toString() : 'CREATED',
                        gmv: parseFloat(o.gmv_gbp) || 0,
                        zone_status: o.zone_status ? o.zone_status.toString() : 'Non-Zone',
                        order_qty: parseInt(o.final_order_qty) || 0
                    }));

                    itemsData = data.items.map(i => ({
                        fleek_id: i.fleek_id ? i.fleek_id.toString() : '',
                        vendor: i.vendor ? i.vendor.toString() : '',
                        item_title: i.item_title ? i.item_title.toString() : '',
                        qty: parseInt(i.quantity) || 0,
                        grade: i.grade ? i.grade.toString() : 'A'
                    }));

                    console.log('Data loaded:', {
                        orders: ordersData.length,
                        items: itemsData.length,
                        sampleOrder: ordersData[0],
                        sampleItem: itemsData[0]
                    });

                    setConnected(true);
                    populateVendors();
                    updateStats();
                    toast(`✅ ${ordersData.length} orders, ${itemsData.length} items loaded`);
                    document.getElementById('statsGrid').style.display = 'grid';
                    errorBanner.style.display = 'none';
                } else {
                    throw new Error(data.message || 'API returned success:false');
                }
            } catch (e) {
                console.error('Load error:', e);
                setConnected(false);
                dropdown.innerHTML = '<option>-- Error Loading --</option>';
                
                errorBanner.style.display = 'block';
                errorMessage.innerHTML = `
                    <strong>❌ Connection Failed</strong><br><br>
                    Error: ${e.message}<br><br>
                    <strong>Troubleshooting:</strong><br>
