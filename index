            cats.forEach(cat => {
                const a = parseInt(document.getElementById(cat + 'A').value) || 0;
                const b = parseInt(document.getElementById(cat + 'B').value) || 0;
                const c = parseInt(document.getElementById(cat + 'C').value) || 0;
                const sum = a + b + c;
                document.getElementById(cat + 'Qty').value = sum || '';
                total += sum;
            });

            document.getElementById('qcTotalQty').textContent = total.toLocaleString();
        }

