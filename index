        function deleteResult(index) {
            if (confirm('Delete this QC result?')) {
                const result = qcResults[index];
                const itemKey = `${result.fleek_id}_${result.item_title}`;
                completedItems.delete(itemKey);
                localStorage.setItem('completedItems', JSON.stringify([...completedItems]));
                
                qcResults.splice(index, 1);
                localStorage.setItem('qcResults', JSON.stringify(qcResults));
                
                renderResults();
                loadItems(currentOrder.fleek_id);
