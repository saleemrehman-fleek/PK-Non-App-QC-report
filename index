        }

        function openVideoModal(fleekId, itemTitle, qty) {
            uploadItemInfo = { 
                fleekId: fleekId, 
                itemTitle: itemTitle, 
                qty: qty,
                vendor: currentOrder.vendor 
            };
            
            selectedVideoFile = null;
            
            document.getElementById('uploadFleekId').textContent = fleekId;
            document.getElementById('uploadVendor').textContent = currentOrder.vendor;
            document.getElementById('uploadItemName').textContent = itemTitle.length > 30 ? itemTitle.substring(0, 30) + '...' : itemTitle;
            document.getElementById('uploadOrigQty').textContent = qty;
            
            document.getElementById('videoQcQty').value = '';
            document.getElementById('videoFile').value = '';
            document.getElementById('selectedFileInfo').style.display = 'none';
            document.getElementById('uploadBtn').disabled = true;
            document.getElementById('uploadProgress').classList.remove('active');
            
            updateUploadPreview();
            
            document.getElementById('videoModal').classList.add('active');
        }

        function closeVideoModal() {
            document.getElementById('videoModal').classList.remove('active');
            uploadItemInfo = null;
            selectedVideoFile = null;
        }

        function updateUploadPreview() {
            if (!uploadItemInfo) return;
            
            const qcQty = document.getElementById('videoQcQty').value || 'X';
            
            const folderName = uploadItemInfo.fleekId + '_' + uploadItemInfo.vendor.replace(/[^a-zA-Z0-9]/g, '_');
            document.getElementById('uploadFolderName').textContent = folderName;
            
            const cleanItemTitle = uploadItemInfo.itemTitle.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 50);
            const fileName = uploadItemInfo.fleekId + '_' + cleanItemTitle + '_' + qcQty + '.mp4';
            document.getElementById('uploadFileName').textContent = fileName;
        }

        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            if (!file.type.startsWith('video/')) {
                toast('Please select a video file', true);
                return;
            }
            
            if (file.size > 100 * 1024 * 1024) {
                toast('File too large. Max 100MB', true);
                return;
            }
            
            selectedVideoFile = file;
            displaySelectedFile(file);
            checkUploadReady();
        }

        function displaySelectedFile(file) {
            const fileSize = (file.size / (1024 * 1024)).toFixed(2) + ' MB';
            const info = document.getElementById('selectedFileInfo');
            
            info.innerHTML = `
                <div class="selected-file">
                    <div class="selected-file-info">
                        <i class="fas fa-file-video"></i>
                        <div>
                            <div class="selected-file-name">${file.name}</div>
                            <div class="selected-file-size">${fileSize}</div>
                        </div>
                    </div>
                    <button class="remove-file-btn" onclick="removeSelectedFile()">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            `;
            
            info.style.display = 'block';
        }

        function removeSelectedFile() {
            selectedVideoFile = null;
            document.getElementById('videoFile').value = '';
            document.getElementById('selectedFileInfo').style.display = 'none';
            document.getElementById('uploadBtn').disabled = true;
        }

        function checkUploadReady() {
            const qcQty = document.getElementById('videoQcQty').value;
            const hasFile = selectedVideoFile !== null;
            const hasQty = qcQty && parseInt(qcQty) > 0;
            
            document.getElementById('uploadBtn').disabled = !(hasFile && hasQty);
            
            if (hasQty) {
                updateUploadPreview();
            }
        }

        document.getElementById('videoQcQty')?.addEventListener('input', () => {
            checkUploadReady();
        });

        function setupDragAndDrop() {
            const uploadArea = document.getElementById('uploadArea');
            if (!uploadArea) return;
            
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                uploadArea.addEventListener(eventName, preventDefaults, false);
            });
            
            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }
            
            ['dragenter', 'dragover'].forEach(eventName => {
                uploadArea.addEventListener(eventName, () => {
                    uploadArea.classList.add('drag-over');
                }, false);
            });
            
            ['dragleave', 'drop'].forEach(eventName => {
                uploadArea.addEventListener(eventName, () => {
                    uploadArea.classList.remove('drag-over');
                }, false);
            });
            
            uploadArea.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                
                if (files.length > 0) {
                    document.getElementById('videoFile').files = files;
                    handleFileSelect({ target: { files: files } });
                }
            }, false);
        }

        async function uploadVideo() {
            if (!selectedVideoFile || !uploadItemInfo) {
                toast('Please select a file and enter QC quantity', true);
                return;
            }
            
            const qcQty = document.getElementById('videoQcQty').value;
            if (!qcQty || parseInt(qcQty) <= 0) {
                toast('Please enter a valid QC quantity', true);
                return;
            }
            
            const uploadBtn = document.getElementById('uploadBtn');
            const progressDiv = document.getElementById('uploadProgress');
            const progressFill = document.getElementById('progressFill');
            const progressText = document.getElementById('progressText');
            
            uploadBtn.disabled = true;
            progressDiv.classList.add('active');
            progressFill.style.width = '0%';
            progressText.textContent = 'Preparing upload...';
            
            try {
                progressFill.style.width = '20%';
                progressText.textContent = 'Reading file...';
                
                const fileData = await fileToBase64(selectedVideoFile);
                
                progressFill.style.width = '40%';
                progressText.textContent = 'Uploading to Google Drive...';
                
                const cleanItemTitle = uploadItemInfo.itemTitle.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 50);
                const fileName = uploadItemInfo.fleekId + '_' + cleanItemTitle + '_' + qcQty + '.mp4';
                
                const uploadData = {
                    action: 'uploadVideo',
                    fleekId: uploadItemInfo.fleekId,
                    vendor: uploadItemInfo.vendor,
                    itemTitle: uploadItemInfo.itemTitle,
                    qcQty: parseInt(qcQty),
                    fileData: fileData,
                    fileName: fileName,
                    mimeType: selectedVideoFile.type
                };
                
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(uploadData)
                });
                
                progressFill.style.width = '80%';
                progressText.textContent = 'Processing...';
                
                const result = await response.json();
                
                progressFill.style.width = '100%';
                
                if (result.success) {
                    progressText.textContent = 'Upload complete!';
                    toast('✅ Video uploaded successfully!');
                    
                    setTimeout(() => {
                        closeVideoModal();
                    }, 1500);
                } else {
                    throw new Error(result.message || 'Upload failed');
                }
                
            } catch (error) {
                console.error('Upload error:', error);
                progressFill.style.width = '0%';
                progressDiv.classList.remove('active');
                toast('❌ Upload failed: ' + error.message, true);
                uploadBtn.disabled = false;
            }
        }

        function fileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => {
                    const base64 = reader.result.split(',')[1];
                    resolve(base64);
                };
                reader.onerror = reject;
                reader.readAsDataURL(file);
            });
        }

        function toast(msg, isError = false, type = '') {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.className = 'toast';
            if (isError) t.classList.add('error');
            if (type === 'warning') t.classList.add('warning');
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        }
    </script>
</body>
</html>
