        async function saveToSheet(result) {
            let saved = JSON.parse(localStorage.getItem('qcResults') || '[]');
            saved.push(result);
            localStorage.setItem('qcResults', JSON.stringify(saved));
            updateBadge();

            const data = {
                action: 'saveQC',
                data: {
                    fleekId: result.fleek_id, vendor: result.vendor, zoneStatus: result.zone_status,
                    itemTitle: result.item_title, originalQty: result.original_qty, totalQCQty: result.qc_qty,
                    normalA: result.normal_a || 0, normalB: result.normal_b || 0, normalC: result.normal_c || 0, normalQty: result.normal_qty || 0,
                    oversizeA: result.oversize_a || 0, oversizeB: result.oversize_b || 0, oversizeC: result.oversize_c || 0, oversizeQty: result.oversize_qty || 0,
                    undersizeA: result.undersize_a || 0, undersizeB: result.undersize_b || 0, undersizeC: result.undersize_c || 0, undersizeQty: result.undersize_qty || 0,
                    reworkA: result.rework_a || 0, reworkB: result.rework_b || 0, reworkC: result.rework_c || 0, reworkQty: result.rework_qty || 0,
                    fakeA: result.fake_a || 0, fakeB: result.fake_b || 0, fakeC: result.fake_c || 0, fakeQty: result.fake_qty || 0,
                    otherBrandA: result.other_brand_a || 0, otherBrandB: result.other_brand_b || 0, otherBrandC: result.other_brand_c || 0, otherBrandQty: result.other_brand_qty || 0,
                    missingTagsA: result.missing_tags_a || 0, missingTagsB: result.missing_tags_b || 0, missingTagsC: result.missing_tags_c || 0, missingTagsQty: result.missing_tags_qty || 0,
                    qcerName: result.qcer_name, submittedAt: result.submitted_at
                }
            };

            try {
                await fetch(API_URL, {
                    method: 'POST',
                    mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                saved = JSON.parse(localStorage.getItem('qcResults') || '[]');
                if (saved.length) {
                    saved[saved.length - 1].synced = true;
                    localStorage.setItem('qcResults', JSON.stringify(saved));
                }
                updateBadge();
                updateStats();
            } catch (e) {
                console.error(e);
                toast('⚠️ Saved locally, will sync later', false, 'warning');
            }
        }

        async function syncPending() {
            let saved = JSON.parse(localStorage.getItem('qcResults') || '[]');
            const unsynced = saved.filter(r => !r.synced);

            if (!unsynced.length) {
                toast('All synced!');
                return;
            }

            toast(`Syncing ${unsynced.length}...`);
            let count = 0;

            for (const r of unsynced) {
                try {
                    await fetch(API_URL, {
                        method: 'POST',
                        mode: 'no-cors',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            fleekId: r.fleek_id, vendor: r.vendor, zoneStatus: r.zone_status,
                            itemTitle: r.item_title, originalQty: r.original_qty, totalQCQty: r.qc_qty,
                            normalA: r.normal_a || 0, normalB: r.normal_b || 0, normalC: r.normal_c || 0, normalQty: r.normal_qty || 0,
                            oversizeA: r.oversize_a || 0, oversizeB: r.oversize_b || 0, oversizeC: r.oversize_c || 0, oversizeQty: r.oversize_qty || 0,
                            undersizeA: r.undersize_a || 0, undersizeB: r.undersize_b || 0, undersizeC: r.undersize_c || 0, undersizeQty: r.undersize_qty || 0,
                            reworkA: r.rework_a || 0, reworkB: r.rework_b || 0, reworkC: r.rework_c || 0, reworkQty: r.rework_qty || 0,
                            fakeA: r.fake_a || 0, fakeB: r.fake_b || 0, fakeC: r.fake_c || 0, fakeQty: r.fake_qty || 0,
                            otherBrandA: r.other_brand_a || 0, otherBrandB: r.other_brand_b || 0, otherBrandC: r.other_brand_c || 0, otherBrandQty: r.other_brand_qty || 0,
                            missingTagsA: r.missing_tags_a || 0, missingTagsB: r.missing_tags_b || 0, missingTagsC: r.missing_tags_c || 0, missingTagsQty: r.missing_tags_qty || 0,
                            qcerName: r.qcer_name, submittedAt: r.submitted_at
                        })
                    });
                    r.synced = true;
                    count++;
                } catch (e) { }
            }

            localStorage.setItem('qcResults', JSON.stringify(saved));
            updateBadge();
            updateStats();
            toast(`✅ Synced ${count}/${unsynced.length}`);
        }

        function exportCSV() {
            const saved = JSON.parse(localStorage.getItem('qcResults') || '[]');
            if (!saved.length) {
                toast('No data to export', true);
                return;
            }

            const headers = ['Fleek ID','Vendor','Zone','Item Title','Original Qty','QC Qty','Normal A','Normal B','Normal C','Normal Qty','Oversize A','Oversize B','Oversize C','Oversize Qty','Undersize A','Undersize B','Undersize C','Undersize Qty','Rework A','Rework B','Rework C','Rework Qty','Fake A','Fake B','Fake C','Fake Qty','Other Brand A','Other Brand B','Other Brand C','Other Brand Qty','Missing Tags A','Missing Tags B','Missing Tags C','Missing Tags Qty','QCer','Submitted At'];
            
            let csv = headers.join(',') + '\n';
            saved.forEach(r => {
                csv += [r.fleek_id, r.vendor, r.zone_status, `"${r.item_title}"`, r.original_qty, r.qc_qty,
                    r.normal_a||'', r.normal_b||'', r.normal_c||'', r.normal_qty||'',
                    r.oversize_a||'', r.oversize_b||'', r.oversize_c||'', r.oversize_qty||'',
                    r.undersize_a||'', r.undersize_b||'', r.undersize_c||'', r.undersize_qty||'',
                    r.rework_a||'', r.rework_b||'', r.rework_c||'', r.rework_qty||'',
                    r.fake_a||'', r.fake_b||'', r.fake_c||'', r.fake_qty||'',
                    r.other_brand_a||'', r.other_brand_b||'', r.other_brand_c||'', r.other_brand_qty||'',
                    r.missing_tags_a||'', r.missing_tags_b||'', r.missing_tags_c||'', r.missing_tags_qty||'',
